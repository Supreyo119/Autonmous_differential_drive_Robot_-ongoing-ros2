<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="bumperbot">

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://bumperbot_description/meshes/base_link.STL"/>
      </geometry>
    </visual>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.033"/>
  </joint>
  <link name="right_wheel">
    <visual>
      <origin rpy="1.57 0 0" xyz="0.0 0.0 0.0"/>
     <geometry>
      <mesh filename="package://bumperbot_description/meshes/wheel_right_link.STL"/>
     </geometry>
    </visual>

   </link> 
   <joint name="wheel_link_right" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <axis xyz="0.0 1.0 0.0"/>
    <origin xyz="0.0 -0.07 0.0" rpy="0.0 0.0 0.0"/>
    


   </joint>
   <link name="left_wheel">
    <visual>
      <origin rpy="-1.57 0 0" xyz="0.0 0.0 0.0"/>
     <geometry>
      <mesh filename="package://bumperbot_description/meshes/wheel_left_link.STL"/>
     </geometry>
    </visual>

   </link> 
   <joint name="wheel_link_left" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <axis xyz="0.0 1.0 0.0"/>
    <origin xyz="0.0 0.07 0.0" rpy="0.0 0.0 0.0"/>
    


   </joint>
   <link name="caster_front_wheel">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://bumperbot_description/meshes/caster_front_link.STL" />
      </geometry>
    </visual>
    
   </link>
   <joint name="base_casterfront_joint" type="fixed">
    <origin xyz="0.04755 0.0 -0.0275" rpy="0.0 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="caster_front_wheel"/>
    <axis xyz="0.0 0.0 0.0"/>
   
   </joint>
   <link name="caster_rear_wheel">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://bumperbot_description/meshes/caster_rear_link.STL" />
      </geometry>
    </visual>
    
   </link>
   <joint name="base_casterrear_joint" type="fixed">
    <origin xyz="-0.04755 0.0 -0.0275" rpy="0.0 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="caster_rear_wheel"/>
    <axis xyz="0.0 0.0 0.0"/>
   
   </joint>


</robot>